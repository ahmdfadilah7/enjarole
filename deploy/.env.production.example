# Salin ke .env.production di root proyek:
#   cp deploy/.env.production.example .env.production

# Domain production
DOMAIN=enjarole.hachiedigitation.com

# PostgreSQL (internal Docker)
POSTGRES_USER=enjarole
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
POSTGRES_DB=enjarole

# JWT — generate: openssl rand -base64 48
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG
JWT_REFRESH_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG_LAIN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS & frontend build (sesuaikan dengan DOMAIN)
CORS_ORIGIN=https://enjarole.hachiedigitation.com
VITE_API_URL=https://enjarole.hachiedigitation.com/api
VITE_WS_URL=https://enjarole.hachiedigitation.com

# MinIO (internal Docker; kredensial production)
MINIO_ACCESS_KEY=GANTI_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=GANTI_MINIO_SECRET_KEY_PANJANG
MINIO_BUCKET=enjarole-media
MINIO_PUBLIC_URL=https://enjarole.hachiedigitation.com/media
