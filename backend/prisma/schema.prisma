generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Character {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String   @map("password_hash")
  displayName       String   @map("display_name")
  username          String   @unique
  avatarUrl         String?  @map("avatar_url")
  bio               String?
  backstory         String?
  personalityTraits Json     @default("[]") @map("personality_traits")
  isActive          Boolean  @default(true) @map("is_active")
  refreshToken      String?  @map("refresh_token")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  posts               Post[]
  comments            Comment[]
  likes               Like[]
  stories             Story[]
  followers           Follow[]             @relation("following")
  following           Follow[]             @relation("follower")
  conversationMembers ConversationMember[]
  messages            Message[]
  notifications       Notification[]

  @@map("characters")
}

model Post {
  id           String    @id @default(uuid())
  characterId  String    @map("character_id")
  content      String
  mediaUrls    Json      @default("[]") @map("media_urls")
  likeCount    Int       @default(0) @map("like_count")
  commentCount Int       @default(0) @map("comment_count")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]

  @@index([characterId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id          String    @id @default(uuid())
  postId      String    @map("post_id")
  characterId String    @map("character_id")
  content     String
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("comments")
}

model Like {
  id          String   @id @default(uuid())
  postId      String   @map("post_id")
  characterId String   @map("character_id")
  createdAt   DateTime @default(now()) @map("created_at")

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([postId, characterId])
  @@map("likes")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  Character @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following Character @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Story {
  id              String   @id @default(uuid())
  characterId     String   @map("character_id")
  mediaUrl        String?  @map("media_url")
  mediaType       String   @default("image") @map("media_type")
  textContent     String?  @map("text_content")
  backgroundColor String?  @map("background_color")
  duration        Int?     @map("duration")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([expiresAt])
  @@map("stories")
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  characterId    String   @map("character_id")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  character    Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([conversationId, characterId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Character    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String   @map("recipient_id")
  type        String
  payload     Json     @default("{}")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  recipient Character @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@map("notifications")
}
