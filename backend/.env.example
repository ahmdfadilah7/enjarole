DATABASE_URL="postgresql://enjarole:enjarole_secret@localhost:5432/enjarole?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret-use-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
# Dev LAN: biarkan kosong atau set ke http://<IP-PC>:5173 — origin jaringan lokal otomatis diizinkan saat NODE_ENV != production
CORS_ORIGIN="http://localhost:5173"
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="enjarole-media"
MINIO_USE_SSL=false
# Untuk akses dari HP/device lain: ganti localhost dengan IP PC, mis. http://192.168.1.10:9000/enjarole-media
MINIO_PUBLIC_URL="http://localhost:9000/enjarole-media"
